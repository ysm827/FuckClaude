---
import { useTranslations, type Lang } from '../i18n/ui';
import { SPONSORS } from '../config/sponsors';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<aside class="sponsors" aria-label={t('sponsors.label')}>
  <div class="wrap sponsors__inner">
    <div class="sponsors__head">
      <span class="sponsors__label">{t('sponsors.label')}</span>
      <a class="sponsors__cta" href="mailto:linxiaotao1993@gmail.com">{t('sponsors.cta')}</a>
    </div>
    <ul class="sponsors__list">
      {
        SPONSORS.map((sponsor) => (
          <li>
            <a
              class="sponsor"
              href={sponsor.url[lang]}
              target="_blank"
              rel="sponsored noopener noreferrer"
              data-ga-event="sponsor_click"
              data-ga-id={sponsor.id}
            >
              <img
                class="sponsor__logo"
                src={sponsor.logo}
                width={sponsor.logoWidth}
                height={sponsor.logoHeight}
                alt={sponsor.name}
              />
              <p class="sponsor__text">
                <strong>{sponsor.headline[lang]}</strong>
                {sponsor.tagline[lang]}
              </p>
              <span class="sponsor__btn">
                {sponsor.cta[lang]}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"></path>
                  <path d="m13 6 6 6-6 6"></path>
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</aside>
